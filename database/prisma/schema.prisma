generator client {
  provider        = "prisma-client-js"
  output          = "../../backend/node_modules/.prisma/client"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model ExpenseApproval {
  id                  String               @id
  expenseId           String
  companyId           String
  ruleId              String?
  status              String
  requestedBy         String
  requestedAt         DateTime             @default(now())
  approvedBy          String?
  approvedAt          DateTime?
  rejectedBy          String?
  rejectedAt          DateTime?
  rejectionReason     String?
  comments            String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @default(now())
  ExpenseApprovalRule ExpenseApprovalRule? @relation(fields: [ruleId], references: [id])

  @@index([approvedBy])
  @@index([companyId])
  @@index([expenseId])
  @@index([requestedBy])
  @@index([status])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model ExpenseApprovalRule {
  id                  String            @id
  companyId           String
  name                String
  description         String?
  enabled             Boolean           @default(true)
  amountThreshold     Decimal?          @db.Decimal(10, 2)
  categoryId          String?
  requireJustificatif Boolean           @default(false)
  approvers           Json              @default("[]")
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @default(now())
  ExpenseApproval     ExpenseApproval[]

  @@index([companyId])
  @@index([enabled])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model ExpenseAttachment {
  id           String    @id
  expenseId    String
  companyId    String
  filename     String
  originalName String
  mimetype     String
  size         Int
  url          String
  uploadedBy   String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now())
  companies    companies @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenses     expenses  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  users        users     @relation(fields: [uploadedBy], references: [id])

  @@index([companyId])
  @@index([expenseId])
  @@index([uploadedBy])
}

model accounts {
  id                                                            String                @id
  company_id                                                    String
  code                                                          String                @db.VarChar(20)
  name                                                          String                @db.VarChar(255)
  type                                                          String                @db.VarChar(50)
  category                                                      String?               @db.VarChar(50)
  parent_id                                                     String?
  is_active                                                     Boolean?              @default(true)
  balance                                                       Decimal               @default(0) @db.Decimal(15, 2)
  description                                                   String?
  created_at                                                    DateTime              @default(now())
  updated_at                                                    DateTime
  companies                                                     companies             @relation(fields: [company_id], references: [id], onDelete: Cascade)
  accounts                                                      accounts?             @relation("accountsToaccounts", fields: [parent_id], references: [id])
  other_accounts                                                accounts[]            @relation("accountsToaccounts")
  bank_statements                                               bank_statements[]
  depreciations_depreciations_asset_account_idToaccounts        depreciations[]       @relation("depreciations_asset_account_idToaccounts")
  depreciations_depreciations_depreciation_account_idToaccounts depreciations[]       @relation("depreciations_depreciation_account_idToaccounts")
  expense_categories                                            expense_categories[]
  expenses                                                      expenses[]
  journal_entry_lines                                           journal_entry_lines[]
  suppliers                                                     suppliers[]

  @@unique([company_id, code])
  @@index([category])
  @@index([company_id])
  @@index([is_active])
  @@index([parent_id])
  @@index([type])
}

model currency_settings {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id        String    @unique(map: "unique_currency_settings_per_company")
  base_currency     String    @default("CDF") @db.VarChar(3)
  auto_update_rates Boolean?  @default(false)
  rate_provider     String?   @default("manual") @db.VarChar(50)
  api_key           String?   @db.VarChar(255)
  last_rate_update  DateTime? @db.Timestamp(6)
  created_at        DateTime? @default(now()) @db.Timestamp(6)
  updated_at        DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  companies         companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([company_id], map: "idx_currency_settings_company")
}

model exchange_rates {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  from_currency  String    @db.VarChar(3)
  to_currency    String    @db.VarChar(3)
  rate           Decimal   @db.Decimal(18, 8)
  effective_date DateTime  @db.Date
  source         String?   @default("manual") @db.VarChar(50)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @default(now()) @updatedAt @db.Timestamp(6)

  @@unique([from_currency, to_currency, effective_date], map: "unique_rate_per_date")
  @@index([from_currency, to_currency, effective_date(sort: Desc)], map: "idx_exchange_rates_currencies_date")
  @@index([effective_date(sort: Desc)], map: "idx_exchange_rates_effective_date")
}

model attendances {
  id           String    @id
  company_id   String
  employee_id  String
  date         DateTime  @db.Date
  check_in     DateTime?
  check_out    DateTime?
  hours_worked Decimal?  @default(0) @db.Decimal(5, 2)
  status       String    @default("present") @db.VarChar(50)
  leave_type   String?   @db.VarChar(50)
  notes        String?
  created_at   DateTime  @default(now())
  updated_at   DateTime
  companies    companies @relation(fields: [company_id], references: [id], onDelete: Cascade)
  employees    employees @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@unique([company_id, employee_id, date])
  @@index([company_id])
  @@index([date])
  @@index([employee_id])
  @@index([status])
}

model audit_logs {
  id            String     @id
  company_id    String?
  user_id       String?
  action        String     @db.VarChar(100)
  entity_id     String?    @db.VarChar(255)
  changes       Json?      @default("{}")
  ip_address    String?    @db.VarChar(45)
  user_agent    String?
  created_at    DateTime   @default(now())
  entity        String     @db.VarChar(100)
  after_state   Json?
  before_state  Json?
  justification String?
  module        String?    @db.VarChar(50)
  user_role     String?    @db.VarChar(50)
  hash          String?    @db.VarChar(64)
  previous_hash String?    @db.VarChar(64)
  reason        String?    @db.VarChar(500)
  companies     companies? @relation(fields: [company_id], references: [id])

  @@index([company_id])
  @@index([created_at])
  @@index([entity_id])
  @@index([entity])
  @@index([user_id])
  @@index([module])
  @@index([action])
}

model domain_events {
  id             String     @id
  type           String     @db.VarChar(100)
  entity_type    String     @db.VarChar(100)
  entity_id      String     @db.VarChar(255)
  data           Json
  metadata       Json
  occurred_at    DateTime   @default(now())
  company_id     String?
  user_id        String?
  correlation_id String?    @db.VarChar(100)
  causation_id   String?    @db.VarChar(100)
  companies      companies? @relation(fields: [company_id], references: [id])

  @@index([company_id])
  @@index([entity_id])
  @@index([type])
  @@index([occurred_at])
}

model bank_statements {
  id                String              @id
  company_id        String
  account_id        String
  statement_number  String              @db.VarChar(100)
  start_date        DateTime            @db.Date
  end_date          DateTime            @db.Date
  opening_balance   Decimal             @default(0) @db.Decimal(15, 2)
  closing_balance   Decimal             @default(0) @db.Decimal(15, 2)
  status            String              @default("draft") @db.VarChar(50)
  imported_at       DateTime?
  reconciled_at     DateTime?
  reconciled_by     String?
  notes             String?
  created_at        DateTime            @default(now())
  updated_at        DateTime
  deleted_at        DateTime?
  accounts          accounts            @relation(fields: [account_id], references: [id])
  companies         companies           @relation(fields: [company_id], references: [id], onDelete: Cascade)
  bank_transactions bank_transactions[]

  @@unique([company_id, statement_number])
  @@index([account_id])
  @@index([company_id])
  @@index([deleted_at])
  @@index([end_date])
  @@index([start_date])
  @@index([status])
}

model bank_transactions {
  id               String          @id
  statement_id     String
  transaction_date DateTime        @db.Date
  value_date       DateTime?       @db.Date
  description      String          @db.VarChar(500)
  reference        String?         @db.VarChar(255)
  amount           Decimal         @db.Decimal(15, 2)
  balance          Decimal?        @db.Decimal(15, 2)
  type             String          @db.VarChar(50)
  category         String?         @db.VarChar(100)
  is_reconciled    Boolean         @default(false)
  reconciled_at    DateTime?
  reconciled_with  String?
  reconciled_type  String?         @db.VarChar(50)
  notes            String?
  created_at       DateTime        @default(now())
  updated_at       DateTime
  bank_statements  bank_statements @relation(fields: [statement_id], references: [id], onDelete: Cascade)

  @@index([is_reconciled])
  @@index([reconciled_with])
  @@index([statement_id])
  @@index([transaction_date])
}

model companies {
  id                                    String                        @id
  name                                  String                        @db.VarChar(255)
  business_name                         String?                       @db.VarChar(255)
  logo_url                              String?                       @db.VarChar(500)
  email                                 String                        @unique @db.VarChar(255)
  phone                                 String?                       @db.VarChar(50)
  address                               String?
  city                                  String?                       @db.VarChar(100)
  country                               String?                       @default("RDC") @db.VarChar(100)
  postal_code                           String?                       @db.VarChar(20)
  nif                                   String?                       @unique @db.VarChar(50)
  rccm                                  String?                       @db.VarChar(50)
  def                                   String?                       @db.VarChar(50)
  currency                              String?                       @default("CDF") @db.VarChar(3)
  invoice_prefix                        String?                       @default("FAC") @db.VarChar(20)
  invoice_numbering_type                String?                       @default("sequential") @db.VarChar(20)
  next_invoice_number                   Int?                          @default(1)
  invoice_template_id                   String?                       @default("template-1-modern") @db.VarChar(50)
  rdc_normalized_enabled                Boolean?                      @default(false)
  default_payment_terms                 String?
  default_due_days                      Int?                          @default(30)
  maxicash_enabled                      Boolean?                      @default(false)
  maxicash_merchant_id                  String?                       @db.VarChar(100)
  maxicash_secret_key                   String?                       @db.VarChar(255)
  maxicash_sub_merchant_id              String?                       @db.VarChar(100)
  maxicash_webhook_url                  String?                       @db.VarChar(500)
  reminders_enabled                     Boolean?                      @default(false)
  reminder_days_before                  Int?                          @default(3)
  reminder_days_after                   Int?                          @default(7)
  reminder_frequency                    String?                       @default("daily") @db.VarChar(20)
  reminder_methods                      String[]                      @default(["email"])
  created_at                            DateTime                      @default(now())
  updated_at                            DateTime
  deleted_at                            DateTime?
  is_system_company                     Boolean?                      @default(false)
  system_type                           String?                       @db.VarChar(50)
  account_type                          AccountType                   @default(STARTUP)
  paypal_client_id                      String?                       @db.VarChar(255)
  paypal_enabled                        Boolean?                      @default(false)
  paypal_mode                           String?                       @default("sandbox") @db.VarChar(20)
  paypal_secret_key                     String?                       @db.VarChar(255)
  paypal_webhook_id                     String?                       @db.VarChar(255)
  visapay_api_key                       String?                       @db.VarChar(255)
  visapay_enabled                       Boolean?                      @default(false)
  visapay_merchant_id                   String?                       @db.VarChar(100)
  visapay_mode                          String?                       @default("sandbox") @db.VarChar(20)
  visapay_secret_key                    String?                       @db.VarChar(255)
  visapay_webhook_url                   String?                       @db.VarChar(500)
  visapay_encryption_method             String?                       @default("symmetric") @db.VarChar(20)
  visapay_encryption_key_id             String?                       @db.VarChar(100)
  visapay_signing_key_id                String?                       @db.VarChar(100)
  visapay_visa_encryption_key_id        String?                       @db.VarChar(100)
  visapay_visa_encryption_public_key    String?
  visapay_client_encryption_key_id      String?                       @db.VarChar(100)
  visapay_client_encryption_private_key String?
  visapay_client_signing_key_id         String?                       @db.VarChar(100)
  visapay_client_signing_private_key    String?
  visapay_visa_signing_key_id           String?                       @db.VarChar(100)
  visapay_visa_signing_public_key       String?
  quotation_prefix                      String?                       @default("DEV") @db.VarChar(10)
  next_quotation_number                 Int?                          @default(1)
  credit_note_prefix                    String?                       @default("AV") @db.VarChar(10)
  next_credit_note_number               Int?                          @default(1)
  datarissage_completed                 Boolean                       @default(false)
  datarissage_completed_at              DateTime?
  timezone                              String?                       @default("Africa/Kinshasa") @db.VarChar(50)
  business_type                         String?                       @db.VarChar(50)
  module_facturation_enabled            Boolean                       @default(true)
  module_comptabilite_enabled           Boolean                       @default(true)
  module_stock_enabled                  Boolean                       @default(false)
  module_rh_enabled                     Boolean                       @default(false)
  stock_management_type                 String?                       @db.VarChar(50)
  stock_tracking_type                   String?                       @db.VarChar(50)
  stock_allow_negative                  Boolean?                      @default(false)
  stock_valuation_method                String?                       @db.VarChar(50)
  rh_organization_type                  String?                       @db.VarChar(50)
  rh_payroll_enabled                    Boolean?                      @default(false)
  rh_payroll_cycle                      String?                       @db.VarChar(50)
  rh_accounting_integration             Boolean?                      @default(false)
  ExpenseAttachment                     ExpenseAttachment[]
  accounts                              accounts[]
  attendances                           attendances[]
  audit_logs                            audit_logs[]
  bank_statements                       bank_statements[]
  batches                               batches[]
  company_accountants                   company_accountants[]
  company_datarissage_settings          company_datarissage_settings?
  contracts                             contracts[]
  credit_notes                          credit_notes[]
  currency_settings                     currency_settings?
  customers                             customers[]
  depreciations                         depreciations[]
  domain_events                         domain_events[]
  employee_documents                    employee_documents[]
  employees                             employees[]
  expense_categories                    expense_categories[]
  expenses                              expenses[]
  file_uploads                          file_uploads[]
  fiscal_periods                        fiscal_periods[]
  idempotency_keys                      idempotency_keys[]
  invoices                              invoices[]
  journal_entries                       journal_entries[]
  leave_balances                        leave_balances[]
  leave_policies                        leave_policies[]
  leave_requests                        leave_requests[]
  notification_templates                notification_templates[]
  notifications                         notifications[]
  onboarding_progress                   onboarding_progress?
  payments                              payments[]
  payrolls                              payrolls[]
  employee_contracts                    employee_contracts[]
  products                              products[]
  quotations                            quotations[]
  recurring_invoices                    recurring_invoices[]
  settings                              settings[]
  stock_movements                       stock_movements[]
  subscriptions                         subscriptions?
  suppliers                             suppliers[]
  support_tickets                       support_tickets[]
  usages                                usages[]
  users                                 users[]
  warehouses                            warehouses[]

  @@index([deleted_at])
  @@index([email])
  @@index([is_system_company])
  @@index([nif])
  @@index([system_type])
}

model company_accountants {
  id               String     @id
  company_id       String
  accountant_id    String
  status           String     @default("pending") @db.VarChar(50)
  invited_by       String?
  invited_at       DateTime   @default(now())
  accepted_at      DateTime?
  rejected_at      DateTime?
  rejection_reason String?
  revoked_at       DateTime?
  revoked_by       String?
  contract_id      String?
  created_at       DateTime   @default(now())
  updated_at       DateTime
  users            users      @relation(fields: [accountant_id], references: [id], onDelete: Cascade)
  companies        companies  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  contracts        contracts? @relation(fields: [contract_id], references: [id])

  @@unique([company_id, accountant_id])
  @@index([accountant_id])
  @@index([company_id])
  @@index([status])
}

model contracts {
  id                   String                @id
  company_id           String
  accountant_id        String
  type                 String                @default("accountant_service") @db.VarChar(50)
  title                String                @db.VarChar(255)
  content              String?
  template_id          String?               @db.VarChar(50)
  file_url             String?               @db.VarChar(500)
  status               String                @default("draft") @db.VarChar(50)
  company_signed_at    DateTime?
  company_signed_by    String?
  accountant_signed_at DateTime?
  accountant_signed_by String?
  start_date           DateTime?
  end_date             DateTime?
  signed_at            DateTime?
  created_at           DateTime              @default(now())
  updated_at           DateTime
  company_accountants  company_accountants[]
  users                users                 @relation(fields: [accountant_id], references: [id], onDelete: Cascade)
  companies            companies             @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([accountant_id])
  @@index([company_id])
  @@index([status])
}

model customers {
  id                 String               @id
  company_id         String
  type               String               @default("particulier") @db.VarChar(50)
  first_name         String?              @db.VarChar(100)
  last_name          String?              @db.VarChar(100)
  business_name      String?              @db.VarChar(255)
  contact_person     String?              @db.VarChar(255)
  email              String?              @db.VarChar(255)
  phone              String?              @db.VarChar(50)
  mobile             String?              @db.VarChar(50)
  address            String?
  city               String?              @db.VarChar(100)
  country            String?              @default("RDC") @db.VarChar(100)
  postal_code        String?              @db.VarChar(20)
  nif                String?              @db.VarChar(50)
  rccm               String?              @db.VarChar(50)
  notes              String?
  tags               String[]             @default([])
  created_at         DateTime             @default(now())
  updated_at         DateTime
  deleted_at         DateTime?
  companies          companies            @relation(fields: [company_id], references: [id], onDelete: Cascade)
  invoices           invoices[]
  quotations         quotations[]
  recurring_invoices recurring_invoices[]

  @@index([company_id])
  @@index([deleted_at])
  @@index([email])
  @@index([type])
}

model depreciations {
  id                                                       String    @id
  company_id                                               String
  asset_account_id                                         String
  depreciation_account_id                                  String
  depreciation_method                                      String    @db.VarChar(50)
  depreciation_rate                                        Decimal   @db.Decimal(5, 2)
  is_active                                                Boolean   @default(true)
  created_at                                               DateTime  @default(now())
  updated_at                                               DateTime
  description                                              String
  end_date                                                 DateTime? @db.Date
  purchase_amount                                          Decimal   @db.Decimal(15, 2)
  purchase_date                                            DateTime  @db.Date
  start_date                                               DateTime  @db.Date
  accounts_depreciations_asset_account_idToaccounts        accounts  @relation("depreciations_asset_account_idToaccounts", fields: [asset_account_id], references: [id])
  companies                                                companies @relation(fields: [company_id], references: [id], onDelete: Cascade)
  accounts_depreciations_depreciation_account_idToaccounts accounts  @relation("depreciations_depreciation_account_idToaccounts", fields: [depreciation_account_id], references: [id])

  @@index([asset_account_id])
  @@index([company_id])
  @@index([depreciation_account_id])
  @@index([is_active])
}

model employee_documents {
  id            String       @id
  company_id    String
  employee_id   String
  document_type String       @db.VarChar(50)
  name          String       @db.VarChar(255)
  description   String?
  file_id       String
  expiry_date   DateTime?    @db.Date
  is_expired    Boolean      @default(false)
  notes         String?
  created_at    DateTime     @default(now())
  updated_at    DateTime
  deleted_at    DateTime?
  companies     companies    @relation(fields: [company_id], references: [id], onDelete: Cascade)
  employees     employees    @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  file_uploads  file_uploads @relation(fields: [file_id], references: [id])

  @@index([company_id])
  @@index([deleted_at])
  @@index([document_type])
  @@index([employee_id])
  @@index([expiry_date])
  @@index([is_expired])
}

model employees {
  id                     String               @id
  company_id             String
  employee_number        String               @db.VarChar(50)
  first_name             String               @db.VarChar(100)
  last_name              String               @db.VarChar(100)
  email                  String?              @db.VarChar(255)
  phone                  String?              @db.VarChar(50)
  mobile                 String?              @db.VarChar(50)
  date_of_birth          DateTime?            @db.Date
  gender                 String?              @db.VarChar(20)
  address                String?
  city                   String?              @db.VarChar(100)
  country                String?              @default("RDC") @db.VarChar(100)
  postal_code            String?              @db.VarChar(20)
  position               String?              @db.VarChar(255)
  department             String?              @db.VarChar(100)
  hire_date              DateTime             @db.Date
  termination_date       DateTime?            @db.Date
  employment_type        String?              @default("full_time") @db.VarChar(50)
  status                 String               @default("active") @db.VarChar(50)
  base_salary            Decimal              @default(0) @db.Decimal(15, 2)
  currency               String?              @default("CDF") @db.VarChar(3)
  salary_frequency       String?              @default("monthly") @db.VarChar(20)
  bank_account           String?              @db.VarChar(100)
  bank_name              String?              @db.VarChar(255)
  nif                    String?              @db.VarChar(50)
  social_security_number String?              @db.VarChar(100)
  notes                  String?
  created_at             DateTime             @default(now())
  updated_at             DateTime
  deleted_at             DateTime?
  manager_id             String?
  attendances            attendances[]
  employee_documents     employee_documents[]
  companies              companies            @relation(fields: [company_id], references: [id], onDelete: Cascade)
  employees              employees?           @relation("employeesToemployees", fields: [manager_id], references: [id])
  other_employees        employees[]          @relation("employeesToemployees")
  leave_balances         leave_balances[]
  leave_requests         leave_requests[]
  payrolls               payrolls[]
  employee_contracts     employee_contracts[]

  @@unique([company_id, employee_number])
  @@index([company_id])
  @@index([deleted_at])
  @@index([department])
  @@index([manager_id])
  @@index([status])
}

model expense_categories {
  id            String     @id
  company_id    String
  name          String     @db.VarChar(255)
  description   String?
  account_id    String?
  is_active     Boolean?   @default(true)
  created_at    DateTime   @default(now())
  updated_at    DateTime
  deleted_at    DateTime?
  display_order Int?       @default(0)
  accounts      accounts?  @relation(fields: [account_id], references: [id])
  companies     companies  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  expenses      expenses[]

  @@index([account_id])
  @@index([company_id])
  @@index([deleted_at])
  @@index([is_active])
}

model expenses {
  id                    String              @id
  company_id            String
  expense_number        String              @db.VarChar(100)
  expense_date          DateTime            @default(now()) @db.Date
  supplier_id           String?
  category_id           String?
  account_id            String?
