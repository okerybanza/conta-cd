/// Table des mouvements de stock (immuable, source de vérité)
/// Le stock courant est calculé à partir de ces mouvements
/// DOC-03 : Un mouvement validé ne se supprime jamais, ne se modifie jamais
model stock_movements {
  id                String                 @id
  company_id        String
  movement_type     String                 @db.VarChar(20)
  reference         String?                @db.VarChar(50)
  reference_id      String?
  reason            String?
  created_by        String?
  created_at        DateTime               @default(now())
  reversed_from_id  String?                @unique(map: "stock_movements_reversed_by_id_key")
  reversed_at       DateTime?
  status            String                 @default("DRAFT") @db.VarChar(20)
  validated_by      String?
  validated_at      DateTime?
  items             stock_movement_items[]
  companies         companies              @relation(fields: [company_id], references: [id], onDelete: Cascade)
  users             users?                 @relation("StockMovementCreated", fields: [created_by], references: [id])
  reverses          stock_movements?       @relation("StockMovementReversal", fields: [reversed_from_id], references: [id], map: "stock_movements_reversed_by_id_fkey")
  reversed_from     stock_movements?       @relation("StockMovementReversal")
  validated_by_user users?                 @relation("StockMovementValidated", fields: [validated_by], references: [id])

  @@index([company_id])
  @@index([movement_type])
  @@index([status])
  @@index([reference, reference_id])
  @@index([created_at])
  @@index([validated_at])
  @@index([reversed_at])
}

/// Lignes de mouvement de stock (stock_movement_items)
/// DOC-03 : Le sens dépend du type, jamais du signe (quantity toujours positive)
model stock_movement_items {
  id                String          @id
  stock_movement_id String
  product_id        String
  warehouse_id      String?
  warehouse_to_id   String?
  quantity          Decimal         @db.Decimal(15, 2)
  batch_id          String?
  serial_number     String?
  created_at        DateTime        @default(now())
  batches           batches?        @relation(fields: [batch_id], references: [id])
  products          products        @relation(fields: [product_id], references: [id], onDelete: Cascade)
  stock_movements   stock_movements @relation(fields: [stock_movement_id], references: [id], onDelete: Cascade)
  warehouse_from    warehouses?     @relation("StockMovementFromWarehouse", fields: [warehouse_id], references: [id])
  warehouse_to      warehouses?     @relation("StockMovementToWarehouse", fields: [warehouse_to_id], references: [id])

  @@index([stock_movement_id])
  @@index([product_id])
  @@index([warehouse_id])
  @@index([batch_id])
  @@index([serial_number])
}

/// Lots (Batches) - Optionnel selon configuration
/// Pour gestion FIFO, dates d'expiration, traçabilité
model batches {
  id                   String                 @id
  company_id           String
  product_id           String
  batch_number         String                 @db.VarChar(100)
  quantity             Decimal                @db.Decimal(15, 2)
  expiry_date          DateTime?              @db.Date
  production_date      DateTime?              @db.Date
  supplier_batch       String?                @db.VarChar(255)
  notes                String?
  created_at           DateTime               @default(now())
  updated_at           DateTime               @updatedAt
  companies            companies              @relation(fields: [company_id], references: [id], onDelete: Cascade)
  products             products               @relation(fields: [product_id], references: [id], onDelete: Cascade)
  stock_movement_items stock_movement_items[]

  @@unique([company_id, product_id, batch_number])
  @@index([company_id])
  @@index([product_id])
  @@index([expiry_date])
}

model quotation_lines {
  id           String     @id
  quotation_id String
  product_id   String?
  description  String
  quantity     Decimal    @default(1) @db.Decimal(15, 2)
  unit_price   Decimal    @db.Decimal(15, 2)
  tax_rate     Decimal    @default(0) @db.Decimal(5, 2)
  tax_amount   Decimal    @default(0) @db.Decimal(15, 2)
  subtotal     Decimal    @default(0) @db.Decimal(15, 2)
  total        Decimal    @default(0) @db.Decimal(15, 2)
  created_at   DateTime   @default(now())
  updated_at   DateTime
  products     products?  @relation(fields: [product_id], references: [id])
  quotations   quotations @relation(fields: [quotation_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@index([quotation_id])
}

model quotations {
  id               String            @id
  company_id       String
  customer_id      String
  quotation_number String            @db.VarChar(100)
  quotation_date   DateTime          @default(now()) @db.Date
  expiration_date  DateTime?         @db.Date
  status           String            @default("draft") @db.VarChar(50)
  currency         String?           @default("CDF") @db.VarChar(3)
  template_id      String?           @default("template-1-modern") @db.VarChar(50)
  notes            String?
  payment_terms    String?
  footer_text      String?
  subtotal         Decimal           @default(0) @db.Decimal(15, 2)
  tax_amount       Decimal           @default(0) @db.Decimal(15, 2)
  total_amount     Decimal           @default(0) @db.Decimal(15, 2)
  reference        String?           @db.VarChar(255)
  po_number        String?           @db.VarChar(255)
  shipping_address String?
  shipping_city    String?           @db.VarChar(100)
  shipping_country String?           @db.VarChar(100)
  transport_fees   Decimal?          @default(0) @db.Decimal(15, 2)
  platform_fees    Decimal?          @default(0) @db.Decimal(15, 2)
  sent_at          DateTime?
  accepted_at      DateTime?
  rejected_at      DateTime?
  expired_at       DateTime?
  invoice_id       String?
  created_by       String?
  created_at       DateTime          @default(now())
  updated_at       DateTime
  deleted_at       DateTime?
  quotation_lines  quotation_lines[]
  companies        companies         @relation(fields: [company_id], references: [id], onDelete: Cascade)
  users            users?            @relation(fields: [created_by], references: [id])
  customers        customers         @relation(fields: [customer_id], references: [id])
  invoices         invoices?         @relation(fields: [invoice_id], references: [id])

  @@unique([company_id, quotation_number])
  @@index([company_id])
  @@index([customer_id])
  @@index([deleted_at])
  @@index([expiration_date])
  @@index([invoice_id])
  @@index([quotation_date])
  @@index([status])
}

model recurring_invoices {
  id                      String                    @id
  company_id              String
  customer_id             String
  name                    String                    @db.VarChar(255)
  description             String?
  frequency               String                    @db.VarChar(50)
  start_date              DateTime                  @db.Date
  end_date                DateTime?                 @db.Date
  next_run_date           DateTime?                 @db.Date
  currency                String?                   @default("CDF") @db.VarChar(3)
  notes                   String?
  payment_terms           String?
  is_active               Boolean                   @default(true)
  created_at              DateTime                  @default(now())
  updated_at              DateTime
  deleted_at              DateTime?
  created_by              String?
  subtotal                Decimal                   @default(0) @db.Decimal(15, 2)
  tax_amount              Decimal                   @default(0) @db.Decimal(15, 2)
  template_id             String?                   @default("template-1-modern") @db.VarChar(50)
  total_amount            Decimal                   @default(0) @db.Decimal(15, 2)
  last_invoice_id         String?
  last_run_date           DateTime?                 @db.Date
  total_generated         Int                       @default(0)
  invoices                invoices[]
  recurring_invoice_lines recurring_invoice_lines[]
  companies               companies                 @relation(fields: [company_id], references: [id], onDelete: Cascade)
  users                   users?                    @relation(fields: [created_by], references: [id])
  customers               customers                 @relation(fields: [customer_id], references: [id])

  @@index([company_id])
  @@index([customer_id])
  @@index([deleted_at])
  @@index([is_active])
  @@index([next_run_date])
}

model settings {
  id         String    @id
  company_id String
  key        String    @db.VarChar(100)
  value      String
  created_at DateTime  @default(now())
  updated_at DateTime
  companies  companies @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@unique([company_id, key])
  @@index([company_id])
}

model subscriptions {
  id                String    @id
  company_id        String    @unique
  package_id        String
  status            String    @default("active") @db.VarChar(50)
  billing_cycle     String    @db.VarChar(20)
  start_date        DateTime  @db.Date
  end_date          DateTime? @db.Date
  trial_ends_at     DateTime?
  cancelled_at      DateTime?
  cancelled_by      String?
  payment_method    String?   @db.VarChar(50)
  last_payment_date DateTime?
  next_payment_date DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime
  companies         companies @relation(fields: [company_id], references: [id], onDelete: Cascade)
  packages          packages  @relation(fields: [package_id], references: [id])

  @@index([company_id])
  @@index([end_date])
  @@index([package_id])
  @@index([status])
}

model suppliers {
  id          String     @id
  company_id  String
  name        String     @db.VarChar(255)
  email       String?    @db.VarChar(255)
  phone       String?    @db.VarChar(50)
  address     String?
  city        String?    @db.VarChar(100)
  country     String?    @default("RDC") @db.VarChar(100)
  postal_code String?    @db.VarChar(20)
  nif         String?    @db.VarChar(50)
  rccm        String?    @db.VarChar(50)
  notes       String?
  created_at  DateTime   @default(now())
  updated_at  DateTime
  deleted_at  DateTime?
  is_active   Boolean?   @default(true)
  account_id  String?
  expenses    expenses[]
  accounts    accounts?  @relation(fields: [account_id], references: [id])
  companies   companies  @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([account_id])
  @@index([company_id])
  @@index([deleted_at])
  @@index([is_active])
}

model support_tickets {
  id          String    @id
  company_id  String
  user_id     String?
  subject     String    @db.VarChar(255)
  category    String    @db.VarChar(50)
  priority    String    @default("medium") @db.VarChar(50)
  status      String    @default("open") @db.VarChar(50)
  response    String?
  created_at  DateTime  @default(now())
  updated_at  DateTime
  attachments String[]  @default([])
  closed_at   DateTime?
  closed_by   String?
  description String
  resolved_at DateTime?
  resolved_by String?
  companies   companies @relation(fields: [company_id], references: [id], onDelete: Cascade)
  users       users?    @relation(fields: [user_id], references: [id])

  @@index([category])
  @@index([company_id])
  @@index([created_at])
  @@index([priority])
  @@index([status])
  @@index([user_id])
}

model usages {
  id          String    @id
  company_id  String
  period      String    @db.VarChar(20)
  metric      String    @db.VarChar(100)
  created_at  DateTime  @default(now())
  updated_at  DateTime
  period_date DateTime  @db.Date
  value       Decimal   @default(0) @db.Decimal(15, 2)
  companies   companies @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@unique([company_id, metric, period, period_date])
  @@index([company_id])
  @@index([metric])
  @@index([period_date])
  @@index([period])
}

model user_accountant_profiles {
  id                      String   @id
  user_id                 String   @unique
  company_name            String?  @db.VarChar(255)
  registration_number     String?  @db.VarChar(100)
  specialization          String[] @default([])
  experience_years        Int?
  country                 String?  @db.VarChar(100)
  province                String?  @db.VarChar(100)
  city                    String?  @db.VarChar(100)
  address                 String?
  professional_email      String?  @db.VarChar(255)
  professional_phone      String?  @db.VarChar(50)
  website                 String?  @db.VarChar(500)
  is_available            Boolean  @default(true)
  max_companies           Int?
  total_companies_managed Int      @default(0)
  active_companies_count  Int      @default(0)
  rating                  Decimal? @default(0) @db.Decimal(3, 2)
  total_reviews           Int      @default(0)
  created_at              DateTime @default(now())
  updated_at              DateTime
  users                   users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([city])
  @@index([country])
  @@index([is_available])
  @@index([province])
}

model users {
  id                                               String                    @id
  company_id                                       String?
  email                                            String                    @unique @db.VarChar(255)
  password_hash                                    String                    @db.VarChar(255)
  first_name                                       String?                   @db.VarChar(100)
  last_name                                        String?                   @db.VarChar(100)
  phone                                            String?                   @db.VarChar(50)
  email_verified                                   Boolean?                  @default(false)
  email_verification_token                         String?                   @db.VarChar(255)
  email_verification_expires_at                    DateTime?
  two_factor_enabled                               Boolean?                  @default(false)
  two_factor_secret                                String?                   @db.VarChar(255)
  two_factor_backup_codes                          String[]
  password_reset_token                             String?                   @db.VarChar(255)
  password_reset_expires_at                        DateTime?
  role                                             String?                   @default("manager") @db.VarChar(50)
  permissions                                      Json?                     @default("{}")
  preferences                                      Json?                     @default("{}")
  language                                         String?                   @default("fr") @db.VarChar(10)
  timezone                                         String?                   @default("Africa/Kinshasa") @db.VarChar(50)
  last_login_at                                    DateTime?
  last_login_ip                                    String?                   @db.VarChar(45)
  failed_login_attempts                            Int?                      @default(0)
  locked_until                                     DateTime?
  created_at                                       DateTime                  @default(now())
  updated_at                                       DateTime
  deleted_at                                       DateTime?
  is_accountant                                    Boolean                   @default(false)
  is_conta_user                                    Boolean                   @default(false)
  is_super_admin                                   Boolean                   @default(false)
  conta_role                                       String?                   @db.VarChar(50)
  conta_permissions                                Json?                     @default("{}")
  ExpenseAttachment                                ExpenseAttachment[]
  company_accountants                              company_accountants[]
  contracts                                        contracts[]
  credit_notes                                     credit_notes[]
  expenses                                         expenses[]
  invoices                                         invoices[]
  journal_entries                                  journal_entries[]
  leave_requests_leave_requests_approved_byTousers leave_requests[]          @relation("leave_requests_approved_byTousers")
  leave_requests_leave_requests_rejected_byTousers leave_requests[]          @relation("leave_requests_rejected_byTousers")
  payments                                         payments[]
  quotations                                       quotations[]
  recurring_invoices                               recurring_invoices[]
  stock_movements_created                          stock_movements[]         @relation("StockMovementCreated")
  stock_movements_validated                        stock_movements[]         @relation("StockMovementValidated")
  support_tickets                                  support_tickets[]
  user_accountant_profiles                         user_accountant_profiles?
  companies                                        companies?                @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([deleted_at])
  @@index([email])
  @@index([is_accountant])
}

model credit_notes {
  id                 String    @id
  company_id         String
  invoice_id         String
  credit_note_number String    @db.VarChar(100)
  credit_note_date   DateTime  @default(now()) @db.Date
  amount             Decimal   @db.Decimal(15, 2)
  tax_amount         Decimal   @default(0) @db.Decimal(15, 2)
  total_amount       Decimal   @db.Decimal(15, 2)
  status             String    @default("draft") @db.VarChar(50)
  reason             String?   @db.VarChar(500)
  reference          String?   @db.VarChar(255)
  currency           String?   @default("CDF") @db.VarChar(3)
  template_id        String?   @default("template-1-modern") @db.VarChar(50)
  notes              String?
  footer_text        String?
  applied_amount     Decimal   @default(0) @db.Decimal(15, 2)
  applied_at         DateTime?
  created_by         String?
  created_at         DateTime  @default(now())
  updated_at         DateTime
  deleted_at         DateTime?
  return_stock       Boolean   @default(false)
  base_currency      String?   @default("CDF") @db.VarChar(3)
  exchange_rate      Decimal?  @default(1.0) @db.Decimal(18, 8)
  base_amount        Decimal?  @db.Decimal(15, 2)
  base_tax_amount    Decimal?  @db.Decimal(15, 2)
  base_total_amount  Decimal?  @db.Decimal(15, 2)
  companies          companies @relation(fields: [company_id], references: [id], onDelete: Cascade)
  users              users?    @relation(fields: [created_by], references: [id])
  invoices           invoices  @relation(fields: [invoice_id], references: [id])

  @@unique([company_id, credit_note_number])
  @@index([company_id])
  @@index([credit_note_date])
  @@index([deleted_at])
  @@index([invoice_id])
  @@index([status])
}

model recurring_invoice_lines {
  id                   String             @id
  recurring_invoice_id String
  product_id           String?
  description          String
  quantity             Decimal            @default(1) @db.Decimal(15, 2)
  unit_price           Decimal            @db.Decimal(15, 2)
  tax_rate             Decimal            @default(0) @db.Decimal(5, 2)
  tax_amount           Decimal            @default(0) @db.Decimal(15, 2)
  subtotal             Decimal            @default(0) @db.Decimal(15, 2)
  total                Decimal            @default(0) @db.Decimal(15, 2)
  created_at           DateTime           @default(now())
  updated_at           DateTime
  products             products?          @relation(fields: [product_id], references: [id])
  recurring_invoices   recurring_invoices @relation(fields: [recurring_invoice_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@index([recurring_invoice_id])
}

model company_datarissage_settings {
  id                            String    @id
  company_id                    String    @unique
  currency_locked               Boolean   @default(false)
  business_type_locked          Boolean   @default(false)
  stock_management_type_locked  Boolean   @default(false)
  stock_valuation_method_locked Boolean   @default(false)
  rh_payroll_enabled_locked     Boolean   @default(false)
  locked_at                     DateTime?
  locked_by                     String?
  created_at                    DateTime  @default(now())
  updated_at                    DateTime
  companies                     companies @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
}

model employee_contracts {
  id                 String    @id
  company_id         String
  employee_id        String
  contract_type      String    @db.VarChar(50)
  start_date         DateTime  @db.Date
  end_date           DateTime? @db.Date
  base_salary        Decimal   @db.Decimal(15, 2)
  currency           String    @default("CDF") @db.VarChar(3)
  work_type          String    @default("full_time") @db.VarChar(50)
  hours_per_week     Decimal?  @db.Decimal(5, 2)
  status             String    @default("active") @db.VarChar(50)
  terminated_at      DateTime?
  terminated_by      String?
  termination_reason String?
  notes              String?
  created_at         DateTime  @default(now())
  updated_at         DateTime
  deleted_at         DateTime?
  companies          companies @relation(fields: [company_id], references: [id], onDelete: Cascade)
  employees          employees @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@unique([employee_id, start_date])
  @@index([company_id])
  @@index([employee_id])
  @@index([status])
  @@index([start_date])
  @@index([end_date])
  @@index([deleted_at])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model idempotency_keys {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id    String    @db.VarChar(255)
  key           String    @db.VarChar(255)
  endpoint      String    @db.VarChar(255)
  request_hash  String
  response_code Int
  response_body Json?
  created_at    DateTime  @default(now()) @db.Timestamp(6)
  expires_at    DateTime  @db.Timestamp(6)
  companies     companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_idempotency_company")

  @@unique([company_id, key], map: "idx_idempotency_company_key")
  @@index([created_at], map: "idx_idempotency_created_at")
  @@index([expires_at], map: "idx_idempotency_expires_at")
}

enum AccountType {
  ENTREPRENEUR
  STARTUP
  ONG_FIRM
  EXPERT_COMPTABLE
}

view account_balances_view {
  accountId String  @id @map("account_id")
  companyId String  @map("company_id")
  balance   Decimal @db.Decimal(15, 2)
}
