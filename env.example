# Configuration PostgreSQL pour Conta
# ====================================
# IMPORTANT: Copiez ce fichier en .env et changez le mot de passe !

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=conta_db
DB_USER=conta_user
DB_PASSWORD=aOpLcu14TmmBfxmkxF1n

# Application Configuration
NODE_ENV=production
APP_URL=https://conta.cd
FRONTEND_URL=https://conta.cd
PORT=3001

# JWT Secret (Générez un secret fort avec: openssl rand -base64 32)
JWT_SECRET=changez_moi_avec_un_secret_fort

# Email Configuration
# Serveur SMTP: mail.kazurihost.com
# Port SSL/TLS: 465 (recommandé) ou 25 (non-SSL, non recommandé)
SMTP_HOST=mail.kazurihost.com
SMTP_PORT=465
SMTP_USER=votre_email@conta.cd
SMTP_PASS=votre_mot_de_passe
SMTP_FROM=noreply@conta.cd
# Email spécifique pour les factures (optionnel, utilise SMTP_FROM si non défini)
SMTP_INVOICE_FROM=facture@conta.cd
# Email spécifique pour les notifications (optionnel, utilise SMTP_FROM si non défini)
SMTP_NOTIF_FROM=notifications@conta.cd

# SMS Configuration - Africa's Talking (à configurer)
SMS_API_KEY=votre_api_key
SMS_USERNAME=votre_username
SMS_SENDER_ID=CONTA

# File Upload Configuration
UPLOAD_DIR=/home/devops/conta.cd/uploads
MAX_FILE_SIZE=5242880

# Security
BCRYPT_ROUNDS=10
SESSION_SECRET=changez_moi_avec_un_secret_fort

# Puppeteer Configuration (PDF Generation)
# Optionnel: Chemin vers Chrome/Chromium si non dans PATH
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
# Timeout pour génération PDF (en ms, défaut: 30000)
# PUPPETEER_TIMEOUT=30000

# Encryption Key (pour chiffrement données sensibles)
# Générer avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=votre_clé_de_64_caractères_hexadécimaux

# Redis Configuration (pour les queues d'emails et SMS)
# Redis est DÉSACTIVÉ par défaut. Pour l'activer, définir REDIS_ENABLED=true ou REDIS_URL
# Option 1: Utiliser REDIS_URL (recommandé pour production)
# REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://:password@localhost:6379

# Option 2: Utiliser les paramètres individuels (définir REDIS_ENABLED=true)
# REDIS_ENABLED=true
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Pour désactiver Redis explicitement (les emails seront envoyés directement, sans queue)
# REDIS_DISABLED=true

