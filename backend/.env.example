PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# CORS
# Liste d'origines autorisées, séparées par des virgules (sans espaces)
# Exemple pour la production :
# CORS_ORIGIN=https://conta.cd,https://www.conta.cd
CORS_ORIGIN=http://localhost:3000

# WhatsApp - Twilio
# Obtenez ces informations depuis votre compte Twilio: https://www.twilio.com/console
WHATSAPP_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_AUTH_TOKEN=your_auth_token_here
WHATSAPP_FROM_NUMBER=whatsapp:+243XXXXXXXXX

# Support
# Email et téléphone pour recevoir les notifications de tickets de support
SUPPORT_EMAIL=support@conta.cd
SUPPORT_PHONE=+243XXXXXXXXX
